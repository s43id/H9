{
  "name": "macro-journal",
  "version": "1.0.0",
  "description": "Macro Research Journal — desktop app",
  "author": "Hassan Emami",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "extract": "node scripts/extract-app.js",
    "build:electron": "tsc -p electron/tsconfig.json",
    "start": "npm run build:electron && electron .",
    "dist:win": "npm run build:electron && electron-builder --win --publish never",
    "dist:mac": "npm run build:electron && electron-builder --mac --publish never",
    "dist:linux": "npm run build:electron && electron-builder --linux --publish never"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.hassanemami.macrojournal",
    "productName": "Macro Journal",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist-electron/**/*",
      "app/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.png",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build-resources/icon.png",
      "category": "Office"
    }
  }
}
